# infra/.env.deploy — operator-local deploy configuration
# Copy this file to infra/.env.deploy and fill in your values.
# infra/.env.deploy is gitignored and must never be committed.

# The URL Cloud Run redirects to after Google OAuth completes.
GOOGLE_REDIRECT_URI=https://your-domain.example.com/auth/callback

# Comma-separated list of origins allowed by the backend CORS policy.
CORS_ALLOWED_ORIGINS=https://your-domain.example.com
