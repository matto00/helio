{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp",
        "--browser",
        "chromium",
        "--executable-path",
        "/usr/local/bin/chromium",
        "--headless",
        "--output-dir",
        ".playwright-mcp",
        "--output-max-size",
        "104857600"
      ]
    }
  }
}
