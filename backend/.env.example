# Database connection
DATABASE_URL=jdbc:postgresql://localhost:5432/helio
DB_USER=
DB_PASSWORD=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback

# File storage backend selection
# Values: local | gcs
# Default: local
HELIO_UPLOADS_BACKEND=local

# Local filesystem uploads root (when HELIO_UPLOADS_BACKEND=local)
# Default: ~/.helio/uploads
# HELIO_UPLOADS_ROOT=/absolute/path/to/uploads

# GCS bucket name (required when HELIO_UPLOADS_BACKEND=gcs)
# Example: helio-uploads-prod
# HELIO_UPLOADS_BUCKET=

# Spark configuration
# SPARK_MASTER_URL=spark://localhost:7077

# HTTP server configuration
# HELIO_HTTP_HOST=0.0.0.0
# HELIO_HTTP_PORT=8080
# PORT=8080

# CORS configuration
# CORS_ALLOWED_ORIGINS=http://localhost:5173
