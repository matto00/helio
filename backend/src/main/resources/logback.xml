<configuration>
  <property name="LOG_LEVEL" value="${LOG_LEVEL:-INFO}" />

  <!-- Select the console appender at startup from LOG_FORMAT. The <if> sits at
       the top level (directly under <configuration>), wrapping two complete
       <root> branches, so it does not nest inside a second-phase element
       (<root>) and avoids the IfNestedWithinSecondPhaseElementSC startup WARN.
       Each appender is defined INSIDE its own branch so only the selected one is
       ever declared — nothing is left unreferenced, so there is no "Appender
       named [...] not referenced" WARN either. True equality means any non-`json`
       value (including typos/unset) resolves to plain text, never a dangling ref
       that would leave the root with no appender. Requires Janino on the
       classpath. -->
  <if condition='p("LOG_FORMAT").equalsIgnoreCase("json")'>
    <then>
      <!-- Structured JSON output for production (Cloud Logging). LogstashEncoder
           includes MDC entries by default. The level field is renamed to a
           top-level `severity` field so Cloud Logging classifies entries. -->
      <appender name="json" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
          <fieldNames>
            <level>severity</level>
          </fieldNames>
        </encoder>
      </appender>
      <root level="${LOG_LEVEL}">
        <appender-ref ref="json" />
      </root>
    </then>
    <else>
      <!-- Human-readable plain-text output (dev/local default). -->
      <appender name="plain" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
          <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
      </appender>
      <root level="${LOG_LEVEL}">
        <appender-ref ref="plain" />
      </root>
    </else>
  </if>
</configuration>
