# .env.example — copy to backend/.env for local development
# All variables have sensible defaults; only set what you need to override.

# ---------------------------------------------------------------------------
# HTTP Server
# ---------------------------------------------------------------------------

# PORT is injected automatically by Cloud Run.
# For local dev, HELIO_HTTP_PORT takes precedence if PORT is not set.
# Default: 8080
# PORT=8080
# HELIO_HTTP_PORT=8080

# Bind address (default: 0.0.0.0)
# HELIO_HTTP_HOST=0.0.0.0

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Option A: full JDBC URL (takes precedence over individual params below)
# DATABASE_URL=jdbc:postgresql://localhost:5432/helio?user=helio&password=helio

# Option B: individual params (all must be set if DATABASE_URL is not used)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=helio
# DB_USER=helio
# DB_PASSWORD=helio

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Root log level for both Akka and Logback. Values: TRACE, DEBUG, INFO, WARN, ERROR
# Default: INFO
# LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------

# Comma-separated list of allowed origins.
# Default: http://localhost:5173 (Vite dev server)
# Production example: CORS_ALLOWED_ORIGINS=https://app.helio.dev
# CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---------------------------------------------------------------------------
# Authentication (Google OAuth -- required)
# ---------------------------------------------------------------------------

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback

# ---------------------------------------------------------------------------
# Akka License
# ---------------------------------------------------------------------------

# Required for production use of Akka. Obtain from https://akka.io/
# AKKA_LICENSE_KEY=your-akka-license-key

# ---------------------------------------------------------------------------
# File Storage
# ---------------------------------------------------------------------------

# Local file system path for uploaded files (default: /tmp/helio)
# HELIO_FILE_STORAGE_PATH=/tmp/helio
