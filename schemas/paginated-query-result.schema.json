{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "paginated-query-result.schema.json",
  "title": "PaginatedQueryResult",
  "description": "Paginated result envelope for panel query execution",
  "type": "object",
  "required": ["rows", "columns", "page", "pageSize", "hasMore"],
  "properties": {
    "rows": {
      "type": "array",
      "items": { "type": "object" },
      "description": "Array of row objects keyed by column name"
    },
    "columns": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Ordered array of column name strings"
    },
    "page": {
      "type": "integer",
      "minimum": 0,
      "description": "0-indexed page number"
    },
    "pageSize": {
      "type": "integer",
      "minimum": 1,
      "maximum": 500,
      "description": "Number of rows per page"
    },
    "hasMore": {
      "type": "boolean",
      "description": "True if additional pages exist beyond the current page"
    }
  },
  "additionalProperties": false
}
