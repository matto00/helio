{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helio.local/schemas/resource-meta.schema.json",
  "title": "ResourceMeta",
  "type": "object",
  "required": ["createdBy", "createdAt", "lastUpdated"],
  "properties": {
    "createdBy": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
