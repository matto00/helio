{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helio.local/schemas/panel-appearance.schema.json",
  "title": "PanelAppearance",
  "type": "object",
  "required": ["background", "color", "transparency"],
  "properties": {
    "background": {
      "type": "string",
      "minLength": 1
    },
    "color": {
      "type": "string",
      "minLength": 1
    },
    "transparency": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "chart": {
      "type": "object",
      "required": ["seriesColors", "legend", "tooltip", "axisLabels"],
      "properties": {
        "seriesColors": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^#[0-9a-fA-F]{6}$"
          },
          "maxItems": 8
        },
        "legend": {
          "type": "object",
          "required": ["show", "position"],
          "properties": {
            "show": {
              "type": "boolean"
            },
            "position": {
              "type": "string",
              "enum": ["top", "bottom", "left", "right"]
            }
          },
          "additionalProperties": false
        },
        "tooltip": {
          "type": "object",
          "required": ["enabled"],
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "axisLabels": {
          "type": "object",
          "required": ["x", "y"],
          "properties": {
            "x": {
              "type": "object",
              "required": ["show"],
              "properties": {
                "show": {
                  "type": "boolean"
                },
                "label": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "y": {
              "type": "object",
              "required": ["show"],
              "properties": {
                "show": {
                  "type": "boolean"
                },
                "label": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
