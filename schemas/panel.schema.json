{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helio.local/schemas/panel.schema.json",
  "title": "Panel",
  "type": "object",
  "required": ["id", "dashboardId", "title", "type", "meta", "appearance", "ownerId"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dashboardId": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "type": {
      "type": "string",
      "enum": ["metric", "chart", "text", "table", "markdown", "image", "divider"]
    },
    "meta": {
      "$ref": "https://helio.local/schemas/resource-meta.schema.json"
    },
    "appearance": {
      "$ref": "https://helio.local/schemas/panel-appearance.schema.json"
    },
    "ownerId": {
      "type": "string",
      "minLength": 1
    },
    "typeId": {
      "type": ["string", "null"]
    },
    "fieldMapping": {
      "type": ["object", "null"]
    },
    "content": {
      "type": ["string", "null"]
    },
    "imageUrl": {
      "type": ["string", "null"]
    },
    "imageFit": {
      "type": ["string", "null"],
      "enum": ["contain", "cover", "fill", null]
    },
    "dividerOrientation": {
      "type": ["string", "null"],
      "enum": ["horizontal", "vertical", null]
    },
    "dividerWeight": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "dividerColor": {
      "type": ["string", "null"],
      "pattern": "^#[0-9A-Fa-f]{3}([0-9A-Fa-f]{3})?$"
    }
  },
  "additionalProperties": false
}
