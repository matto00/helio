{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helio.local/schemas/panel.schema.json",
  "title": "Panel",
  "type": "object",
  "required": ["id", "dashboardId", "title", "meta", "appearance"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dashboardId": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "meta": {
      "$ref": "https://helio.local/schemas/resource-meta.schema.json"
    },
    "appearance": {
      "$ref": "https://helio.local/schemas/panel-appearance.schema.json"
    }
  },
  "additionalProperties": false
}
