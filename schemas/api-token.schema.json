{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helio.local/schemas/api-token.schema.json",
  "title": "ApiTokenResponse",
  "description": "Personal Access Token metadata as returned by GET /api/tokens. Never contains the raw token or its hash.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "name": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "lastUsedAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["id", "name", "createdAt"],
  "additionalProperties": false
}
